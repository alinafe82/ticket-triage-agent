# Application Settings
APP_NAME="Ticket Triage Agent"
APP_VERSION="0.2.0"
ENVIRONMENT="development"
DEBUG="false"

# Server Settings
HOST="0.0.0.0"
PORT="8000"
WORKERS="1"

# API Settings
API_PREFIX="/api/v1"
CORS_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000"]'
CORS_ALLOW_CREDENTIALS="false"
EXPOSE_DOCS="true"

# LLM Provider Settings
# Options: mock, openai, anthropic
LLM_PROVIDER="mock"
LLM_API_KEY=""
LLM_MODEL=""
LLM_TIMEOUT="30"
LLM_MAX_RETRIES="3"

# ML Router Settings
ROUTER_MODEL_PATH="models/router.pkl"
ROUTER_CONFIDENCE_THRESHOLD="0.5"

# Logging Settings
LOG_LEVEL="INFO"
LOG_FORMAT="json"

# Monitoring
ENABLE_METRICS="true"
